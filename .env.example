# DATABASE 
DATABASE_URL=postgresql://dataharvest:dataharvest@localhost:5433/dataharvest

# REDIS
REDIS_URL=redis://localhost:6379

# CONCURRENCY
SCRAPER_CONCURRENCY=3
TRANSFORMER_CONCURRENCY=5
